# ── LLM Provider Selection ──────────────────────────────
# Choose one: deepseek | openai | anthropic | ollama
LLM_PROVIDER=deepseek

# ── DeepSeek (default) ──────────────────────────────────
# Available models (2026-04):
#   deepseek-v4-pro    — flagship, highest quality
#   deepseek-v4-flash   — cheaper / faster (recommended default)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# ── OpenAI (optional, used when LLM_PROVIDER=openai) ────
# Recommended models (2026-04):
#   gpt-5.5            — flagship, best quality
#   gpt-5.5-mini       — balanced cost / quality (recommended default)
#   gpt-5.5-nano       — cheapest, simple tasks
# OPENAI_API_KEY=sk-your-openai-api-key
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-5.5-mini

# ── Anthropic / Claude (optional) ───────────────────────
# Requires: pip install langchain-anthropic
# Recommended models (2026-04):
#   claude-opus-4-7    — top-tier capability
#   claude-sonnet-4-7  — recommended default (best price / perf)
#   claude-haiku-4-7   — fastest / cheapest
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
# ANTHROPIC_MODEL=claude-sonnet-4-7

# ── Ollama — local model, no API key required ──────────
# Install Ollama from https://ollama.com, then pull a model:
#   ollama pull qwen3.5-coder:7b      (recommended, ~4.5GB)
#   ollama pull qwen3.5-coder:1.5b    (lightweight, low-RAM machines)
#   ollama pull qwen3.5-coder:32b     (large, GPU recommended)
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=qwen3.5-coder:7b

# ── E2B Sandbox ─────────────────────────────────────────
E2B_API_KEY=e2b_your-e2b-api-key
E2B_SANDBOX_TIMEOUT=60

# ── Agent Behavior ──────────────────────────────────────
MAX_RETRIES=3

# ── LangSmith Observability (Optional) ──────────────────
# Get your API key from https://smith.langchain.com
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls__your-langsmith-api-key
# LANGCHAIN_PROJECT=auto-sdet
